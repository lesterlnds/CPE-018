        "# 6. Change Outcome to Diagnosis\n",
        "df = df.rename(columns={'Outcome': 'Diagnosis'})\n",
        "\n",
        "# 7. Create Classification column\n",
        "df['Classification'] = df['Diagnosis'].apply(lambda x: 'Diabetes' if x == 1 else 'No Diabetes')\n",
        "\n",
        "# 8. Dataframe with diabetes\n",
        "withDiabetes = df[df['Diagnosis'] == 1]\n",
        "\n",
        "# 9. Dataframe with no diabetes\n",
        "noDiabetes = df[df['Diagnosis'] == 0]\n",
        "\n",
        "# 10. Pedia (age 0–19)\n",
        "Pedia = df[df['Age'] <= 19]\n",
        "\n",
        "# 11. Adult (age >19)\n",
        "Adult = df[df['Age'] > 19]\n",
        "\n",
        "# 12. Average age and glucose\n",
        "avg_age = np.mean(df['Age'])\n",
        "avg_glucose = np.mean(df['Glucose'])\n",
        "print(\"\\nAverage Age:\", avg_age)\n",
        "print(\"Average Glucose:\", avg_glucose)\n",
        "\n",
        "# 13. Median age and glucose\n",
        "median_age = np.median(df['Age'])\n",
        "median_glucose = np.median(df['Glucose'])\n",
        "print(\"\\nMedian Age:\", median_age)\n",
        "print(\"Median Glucose:\", median_glucose)\n",
